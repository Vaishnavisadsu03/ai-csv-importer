# Server
PORT=4000
NODE_ENV=development

# Groq — get key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Recommended model: llama-3.3-70b-versatile
# - Supports json_object response mode (structured JSON guaranteed)
# - 128K context window
# - 30 RPM / 6000 TPM on free tier
# DO NOT use: openai/gpt-oss-120b — this model does not exist on Groq's API
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0

# Batch processing
# Free tier (6000 TPM): BATCH_SIZE=5, DELAY=3000ms
# Paid tier: BATCH_SIZE=25, DELAY=500ms
BATCH_SIZE=5
MAX_RETRIES=3
RETRY_DELAY_MS=5000
DELAY_BETWEEN_BATCHES_MS=3000

# File upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:3000
