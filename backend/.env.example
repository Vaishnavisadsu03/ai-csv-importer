# Server
PORT=4000
NODE_ENV=development

# Groq (free tier — get key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_TOKENS=8192
GROQ_TEMPERATURE=0

# Batch processing
# openai/gpt-oss-120b on Groq: 500+ t/s, 30 RPM free tier, 128K context
# 25 rows/batch + 2.5s delay = ~215 batches for 5000 rows = ~9 min free
BATCH_SIZE=25
MAX_RETRIES=3
RETRY_DELAY_MS=5000
DELAY_BETWEEN_BATCHES_MS=2500

# File upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# CORS
CORS_ORIGIN=http://localhost:3000
